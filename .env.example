# Anthropic API (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: shared secret for /api/garmin-sync and /api/garmin-routes on Vercel.
# If unset, ANTHROPIC_API_KEY is used as the internal secret.
# GARMIN_INTERNAL_SECRET=a-long-random-string
