# Anthropic API (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: protect /api/garmin-sync and /api/garmin-routes
# GARMIN_INTERNAL_SECRET=a-long-random-string

# Optional: if Vercel Deployment Protection is enabled, create a bypass secret
# in Project Settings → Deployment Protection, then set it here too:
# VERCEL_AUTOMATION_BYPASS_SECRET=your-bypass-secret
